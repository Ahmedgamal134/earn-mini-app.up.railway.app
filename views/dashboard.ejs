<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - Earn Mini App</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: #f5f5f5;
        }
        
        .navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        
        .navbar h1 {
            font-size: 24px;
        }
        
        .navbar a {
            color: white;
            text-decoration: none;
            background: rgba(255,255,255,0.2);
            padding: 8px 16px;
            border-radius: 8px;
            transition: background 0.3s;
        }
        
        .navbar a:hover {
            background: rgba(255,255,255,0.3);
        }
        
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            padding: 20px;
        }
        
        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        .stat-card h3 {
            color: #666;
            font-size: 16px;
            margin-bottom: 10px;
        }
        
        .stat-card .value {
            color: #333;
            font-size: 28px;
            font-weight: bold;
        }
        
        .users-section {
            padding: 20px;
        }
        
        .users-section h2 {
            margin-bottom: 20px;
            color: #333;
        }
        
        table {
            width: 100%;
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        
        th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            text-align: center;
        }
        
        td {
            padding: 15px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }
        
        tr:hover {
            background: #f9f9f9;
        }
        
        .btn-edit, .btn-view {
            border: none;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            margin: 0 5px;
        }
        
        .btn-edit {
            background: #4CAF50;
            color: white;
        }
        
        .btn-view {
            background: #2196F3;
            color: white;
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
        }
        
        .modal-content {
            background: white;
            margin: 50px auto;
            padding: 30px;
            border-radius: 20px;
            width: 90%;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
        }
        
        .close {
            float: left;
            font-size: 28px;
            cursor: pointer;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
        }
        
        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }
        
        .withdrawal-item {
            border: 1px solid #ddd;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 8px;
        }
        
        .withdrawal-pending {
            border-right: 4px solid #ff9800;
        }
        
        .withdrawal-approved {
            border-right: 4px solid #4CAF50;
        }
        
        .withdrawal-rejected {
            border-right: 4px solid #f44336;
        }
        
        .btn-approve {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 3px;
            cursor: pointer;
            margin-left: 5px;
        }
        
        .btn-reject {
            background: #f44336;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 3px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <h1>🔐 لوحة تحكم المشرف - Earn Mini App</h1>
        <a href="/admin/logout">تسجيل خروج</a>
    </div>
    
    <div class="stats">
        <div class="stat-card">
            <h3>إجمالي المستخدمين</h3>
            <div class="value"><%= stats.totalUsers %></div>
        </div>
        <div class="stat-card">
            <h3>إجمالي النقاط</h3>
            <div class="value"><%= stats.totalPoints.toLocaleString() %></div>
        </div>
        <div class="stat-card">
            <h3>إجمالي المسحوبات</h3>
            <div class="value"><%= stats.totalWithdrawn.toLocaleString() %></div>
        </div>
        <div class="stat-card">
            <h3>طلبات معلقة</h3>
            <div class="value"><%= stats.pendingWithdrawals %></div>
        </div>
    </div>
    
    <div class="users-section">
        <h2>📋 قائمة المستخدمين</h2>
        <table>
            <thead>
                <tr>
                    <th>المستخدم</th>
                    <th>النقاط</th>
                    <th>رصيد المحفظة</th>
                    <th>الأصدقاء</th>
                    <th>آخر نشاط</th>
                    <th>التحكم</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                <tr>
                    <td><%= user.username %></td>
                    <td><%= user.points.toLocaleString() %></td>
                    <td><%= (user.walletBalance || 0).toLocaleString() %></td>
                    <td><%= (user.referrals || []).length %></td>
                    <td><%= user.lastActive ? new Date(user.lastActive).toLocaleDateString('ar-EG') : 'غير معروف' %></td>
                    <td>
                        <button class="btn-edit" onclick="editUser('<%= user.username %>')">تعديل</button>
                        <button class="btn-view" onclick="viewUser('<%= user.username %>')">عرض</button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    
    <!-- Edit User Modal -->
    <div id="editModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal('editModal')">&times;</span>
            <h2 id="editModalTitle">تعديل نقاط المستخدم</h2>
            
            <div class="form-group">
                <label>المستخدم</label>
                <input type="text" id="editUsername" readonly>
            </div>
            
            <div class="form-group">
                <label>الإجراء</label>
                <select id="editAction">
                    <option value="set">تعيين النقاط</option>
                    <option value="add">إضافة نقاط</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>عدد النقاط</label>
                <input type="number" id="editPoints" min="0" value="0">
            </div>
            
            <button onclick="saveUserPoints()" style="width:100%;padding:12px;background:#4CAF50;color:white;border:none;border-radius:5px;cursor:pointer;">حفظ التعديلات</button>
        </div>
    </div>
    
    <!-- View User Modal -->
    <div id="viewModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal('viewModal')">&times;</span>
            <h2 id="viewModalTitle">بيانات المستخدم</h2>
            
            <div id="userDetails"></div>
            
            <h3 style="margin-top:20px;">طلبات السحب</h3>
            <div id="withdrawalsList"></div>
        </div>
    </div>
    
    <script>
        let currentUser = null;
        
        function editUser(username) {
            currentUser = username;
            document.getElementById('editUsername').value = username;
            document.getElementById('editModal').style.display = 'block';
        }
        
        async function viewUser(username) {
            const response = await fetch(`/admin/api/user/${username}`);
            const user = await response.json();
            
            currentUser = username;
            
            let html = `
                <table style="width:100%;margin:20px 0;">
                    <tr><th>الحقل</th><th>القيمة</th></tr>
                    <tr><td>اسم المستخدم</td><td>${user.username}</td></tr>
                    <tr><td>النقاط</td><td>${user.points.toLocaleString()}</td></tr>
                    <tr><td>رصيد المحفظة</td><td>${(user.walletBalance || 0).toLocaleString()}</td></tr>
                    <tr><td>الأصدقاء المدعوين</td><td>${(user.referrals || []).length}</td></tr>
                    <tr><td>تاريخ التسجيل</td><td>${user.createdAt ? new Date(user.createdAt).toLocaleDateString('ar-EG') : 'غير معروف'}</td></tr>
                    <tr><td>آخر نشاط</td><td>${user.lastActive ? new Date(user.lastActive).toLocaleDateString('ar-EG') : 'غير معروف'}</td></tr>
                </table>
            `;
            
            document.getElementById('userDetails').innerHTML = html;
            
            let withdrawalsHtml = '';
            if (user.pendingWithdrawals && user.pendingWithdrawals.length > 0) {
                user.pendingWithdrawals.forEach((w, index) => {
                    withdrawalsHtml += `
                        <div class="withdrawal-item withdrawal-${w.status}">
                            <strong>${w.methodName}</strong><br>
                            المبلغ: ${w.amountEGP} جنيه (${w.points} نقطة)<br>
                            التاريخ: ${new Date(w.date).toLocaleDateString('ar-EG')}<br>
                            الحالة: ${w.status === 'pending' ? 'معلق' : w.status === 'approved' ? 'تمت الموافقة' : 'مرفوض'}<br>
                            ${w.accountDetails}<br>
                            ${w.status === 'pending' ? 
                                `<button class="btn-approve" onclick="processWithdrawal('${w._id}', 'approve')">موافقة</button>
                                 <button class="btn-reject" onclick="processWithdrawal('${w._id}', 'reject')">رفض</button>` 
                                : ''}
                        </div>
                    `;
                });
            } else {
                withdrawalsHtml = '<p>لا توجد طلبات سحب</p>';
            }
            
            document.getElementById('withdrawalsList').innerHTML = withdrawalsHtml;
            document.getElementById('viewModal').style.display = 'block';
        }
        
        async function processWithdrawal(id, action) {
            if (!confirm(`تأكيد ${action === 'approve' ? 'الموافقة' : 'الرفض'} على طلب السحب؟`)) return;
            
            const response = await fetch(`/admin/api/withdrawal/${id}/${action}`, {
                method: 'POST'
            });
            
            const result = await response.json();
            if (result.success) {
                alert('تمت العملية بنجاح');
                location.reload();
            } else {
                alert('حدث خطأ');
            }
        }
        
        async function saveUserPoints() {
            const points = parseInt(document.getElementById('editPoints').value);
            const action = document.getElementById('editAction').value;
            
            if (!confirm(`تأكيد ${action === 'set' ? 'تعيين' : 'إضافة'} ${points} نقطة للمستخدم ${currentUser}؟`)) return;
            
            const response = await fetch('/admin/api/user/update-points', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    username: currentUser,
                    points: points,
                    action: action
                })
            });
            
            const result = await response.json();
            if (result.success) {
                alert('تم تعديل النقاط بنجاح');
                closeModal('editModal');
                location.reload();
            } else {
                alert('حدث خطأ');
            }
        }
        
        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }
        
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = 'none';
            }
        }
    </script>
</body>
</html>
